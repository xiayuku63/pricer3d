# ── Environment ──
# development | production
APP_ENV=development

# ── Secrets ──
# 生产环境必须为每个实例生成独立随机密钥
JWT_SECRET_KEY=dev-key-change-in-production
PAYMENT_WEBHOOK_SECRET=dev-webhook-change-in-production

# ── Database ──
# SQLite 文件路径（Docker 中自动设为 /app/data/app.db）
DB_PATH=app.db

# ── Email (至少配置一个) ──
# 方式 1: Resend API (推荐，简单)
#   注册 https://resend.com → 获取 API Key → 验证发件域名
# RESEND_API_KEY=re_xxxxxxxxxxxx

# 方式 2: 自建 SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# ── Dev ──
# 开发环境设为 true，验证码会在接口响应中返回 dev_code
SHOW_DEV_CODES=true

# ── Payment ──
PAYMENT_PROVIDER=mock

# ── Directories ──
UPLOADS_DIR=uploads
OUTPUTS_DIR=outputs
USER_DATA_DIR=user

# ── Logging ──
LOG_LEVEL=DEBUG

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:3000,http://127.0.0.1:3000
