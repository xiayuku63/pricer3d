solid test_box
  facet normal 0 0 -1
    outer loop
      vertex 0 0 0
      vertex 300 0 0
      vertex 300 300 0
    endloop
  endfacet
  facet normal 0 0 -1
    outer loop
      vertex 0 0 0
      vertex 300 300 0
      vertex 0 300 0
    endloop
  endfacet
  facet normal 0 0 1
    outer loop
      vertex 0 0 100
      vertex 300 300 100
      vertex 300 0 100
    endloop
  endfacet
  facet normal 0 0 1
    outer loop
      vertex 0 0 100
      vertex 0 300 100
      vertex 300 300 100
    endloop
  endfacet
  facet normal 0 -1 0
    outer loop
      vertex 0 0 0
      vertex 300 0 100
      vertex 300 0 0
    endloop
  endfacet
  facet normal 0 -1 0
    outer loop
      vertex 0 0 0
      vertex 0 0 100
      vertex 300 0 100
    endloop
  endfacet
  facet normal 0 1 0
    outer loop
      vertex 0 300 0
      vertex 300 300 0
      vertex 300 300 100
    endloop
  endfacet
  facet normal 0 1 0
    outer loop
      vertex 0 300 0
      vertex 300 300 100
      vertex 0 300 100
    endloop
  endfacet
  facet normal -1 0 0
    outer loop
      vertex 0 0 0
      vertex 0 300 0
      vertex 0 300 100
    endloop
  endfacet
  facet normal -1 0 0
    outer loop
      vertex 0 0 0
      vertex 0 300 100
      vertex 0 0 100
    endloop
  endfacet
  facet normal 1 0 0
    outer loop
      vertex 300 0 0
      vertex 300 0 100
      vertex 300 300 100
    endloop
  endfacet
  facet normal 1 0 0
