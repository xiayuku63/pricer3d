APP_ENV=production
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_STRING
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM=noreply@example.com
BAMBU_EXECUTABLE=/usr/local/bin/bambu-studio
BAMBU_PROFILE_DIR=/app/profiles/bambu
UPLOADS_DIR=/app/data/uploads
OUTPUTS_DIR=/app/data/outputs
USER_DATA_DIR=/app/data/user
DB_PATH=/app/data/app.db
BACKUP_DIR=/app/data/backups
LOG_DIR=/app/data/logs
LOG_LEVEL=INFO
ALLOWED_ORIGINS=https://www.pricer3d.top,https://pricer3d.top
